# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here

# ============================================================================
# IMPORTANT: OpenRouter API Key Configuration
# ============================================================================
# The OPENROUTER_API_KEY is NOT set here - it must be set in Supabase Edge Function secrets
# 
# To set the OpenRouter API key:
# 1. Go to Supabase Dashboard → Edge Functions → Settings → Secrets
# 2. Add a new secret:
#    - Name: OPENROUTER_API_KEY
#    - Value: (your OpenRouter API key)
# 3. Save and wait 1-2 minutes for functions to restart
#
# Model ID: google/gemini-2.5-flash-lite
# ============================================================================

# Optional: WhatsApp Configuration (if using WhatsApp webhooks)
# META_APP_SECRET=your_meta_app_secret
# WHATSAPP_VERIFY_TOKEN=ai_business_chat_verify

# ============================================================================
# Cloudflare R2 Configuration (for Payment Screenshots)
# ============================================================================
# Get these from Cloudflare Dashboard → R2 → Manage R2 API Tokens
# 1. Go to https://dash.cloudflare.com/
# 2. Select your account
# 3. Go to R2 → Manage R2 API Tokens
# 4. Create API Token with Object Read & Write permissions
# 5. Get Account ID from R2 dashboard URL or account settings
# 6. Create a bucket and set it to public (or use custom domain)
# 7. If using custom domain, set VITE_CLOUDFLARE_PUBLIC_URL to your domain
VITE_CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
VITE_CLOUDFLARE_ACCESS_KEY_ID=your_r2_access_key_id
VITE_CLOUDFLARE_SECRET_ACCESS_KEY=your_r2_secret_access_key
VITE_CLOUDFLARE_BUCKET_NAME=payment-proofs
VITE_CLOUDFLARE_PUBLIC_URL=https://your-custom-domain.com

# ============================================================================
# Resend Email Configuration (Set in Supabase Edge Function Secrets)
# ============================================================================
# To set Resend secrets:
# 1. Go to Supabase Dashboard → Edge Functions → Settings → Secrets
# 2. Add:
#    - RESEND_API_KEY: (your Resend API key)
#    - RESEND_SENDER_EMAIL: (your verified sender email, e.g., onboarding@resend.dev)
#    - RESEND_SENDER_NAME: (your preferred sender name, e.g., Reply Ready Bot)
# ============================================================================

# Note: Rename this file to .env and fill in your actual values
# DO NOT commit your .env file with real credentials to version control

